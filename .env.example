# ═══════════════════════════════════════════════════════════════
# XA-LMS Environment Variables — copy relevant sections to each
# service. Never commit actual .env files.
# ═══════════════════════════════════════════════════════════════

# ─── API (copy to api/.env) ─────────────────────────────────────
PORT=8080
APP_ENV=development

# Web app base URL — used to build the links sent in invitation/verification
# emails (e.g. https://xa-lms.example.com). REQUIRED in production: if unset,
# the API silently falls back to http://localhost:3000, which only works on
# the machine that sent the email, not the recipient's.
APP_BASE_URL=http://localhost:3000

# File uploads
# Local fallback (single dev, files not shared):
UPLOAD_DIR=./uploads
API_PUBLIC_URL=http://localhost:8080
# Shared VPS file server (set both to share files across devs):
# Build: cd api && GOOS=linux GOARCH=amd64 go build -o fileserver ./cmd/fileserver
# Deploy: scp fileserver root@72.60.203.40:/opt/xa-fileserver/
# Run on VPS: PORT=9000 UPLOAD_DIR=/var/www/xa-uploads SECRET=xa_files_2026 PUBLIC_URL=http://72.60.203.40:9000 ./fileserver
FILE_SERVER_URL=http://72.60.203.40:9000
FILE_SERVER_SECRET=xa_files_2026

# Database
# Database
# Local Docker (uncomment to switch back to local)
# DB_URL=postgres://xalms:xalms123@localhost:5432/xalms_dev?sslmode=disable
# Shared VPS Dev DB
DB_URL=postgres://xalms:xalms_secure_2026@72.60.203.40:5435/xalms_dev?sslmode=disable

# GORM SQL log verbosity: silent | error | warn | info
# Default is "warn" (only slow queries + errors). Set "info" to log every SQL
# statement when debugging. Production defaults to "silent".
# DB_LOG_LEVEL=warn

# Redis
# Local Docker (uncomment to switch back to local)
# REDIS_URL=redis://localhost:6379
# Shared VPS Redis
REDIS_URL=redis://:redis_secure_2026@72.60.203.40:6382


# Auth
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=168h

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ─── AI Provider — OpenAI ────────────────────────────────────────
# AI_MODEL_EMBED is REQUIRED for any RAG feature (AI Study Companion, the
# AI coach's search_resources tool) — AI_MODEL alone is a chat model and
# will 403 on /embeddings. Its dimension must match ai_doc_chunks.embedding
# vector(1536) in internal/ai/rag/init.go — if you change embedding models,
# update that column's dimension and re-index (old chunks won't match).
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini
AI_MODEL_EMBED=text-embedding-3-small  # 1536 dims — matches the default schema, no migration needed
# AI_MODEL_EMBED=text-embedding-3-small  # 1536 dims — matches the default schema, no migration needed

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=xa-lms-dev
SES_FROM_EMAIL=noreply@xalms.com

# ─── Zoom ─────────────────────────────────────────────────────────
# Meeting SDK (join signature) — https://marketplace.zoom.us Meeting SDK app
ZOOM_MEETING_SDK_CLIENT_ID=
ZOOM_MEETING_SDK_CLIENT_SECRET=
# Server-to-Server OAuth app (used only by internal/zoom/oauth.go)
ZOOM_S2S_ACCOUNT_ID=
ZOOM_S2S_CLIENT_ID=
ZOOM_S2S_CLIENT_SECRET=
# User-authorization OAuth app (faculty "Connect Zoom" flow) — General App,
# grant type = authorization_code, redirect_uri must match the app's config
ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=
ZOOM_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/zoom/oauth/callback
# 32-byte key, base64-encoded, for AES-256-GCM encryption of stored OAuth
# tokens at rest. Generate with: openssl rand -base64 32
ZOOM_TOKEN_ENCRYPTION_KEY=
# Webhook signing secret from the Zoom app's Feature > Event Subscriptions
ZOOM_WEBHOOK_SECRET_TOKEN=

# ─── Web (copy to apps/web/.env.local) ──────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_in_production
# Reuse same Google credentials from API section above

# ─── Mobile (copy to apps/mobile/.env) ──────────────────────────
# Replace with your machine's local IP (run: ipconfig or ifconfig)
EXPO_PUBLIC_API_URL=http://192.168.x.x:8080/api/v1

# Developer OTP login (dev only — set true to enable the OTP sign-in option)
ENABLE_OTP_LOGIN=false
DEV_OTP_CODE=090999
