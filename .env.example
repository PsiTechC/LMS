# ═══════════════════════════════════════════════════════════════
# XA-LMS Environment Variables — copy relevant sections to each
# service. Never commit actual .env files.
# ═══════════════════════════════════════════════════════════════

# ─── API (copy to api/.env) ─────────────────────────────────────
PORT=8080
APP_ENV=development

# Database
DB_URL=postgres://xalms:xalms123@localhost:5432/xalms_dev?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=168h

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ─── AI Provider — swap URL/key to switch, zero code changes ────
# Option 1: Local Ollama (Qwen on your 5090)
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=qwen2.5:32b

# Option 2: Azure OpenAI
# AI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/deployments/gpt-4o
# AI_API_KEY=your_azure_key
# AI_MODEL=gpt-4o

# Option 3: OpenAI direct
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=xa-lms-dev
SES_FROM_EMAIL=noreply@xalms.com

# ─── Web (copy to apps/web/.env.local) ──────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_in_production
# Reuse same Google credentials from API section above

# ─── Mobile (copy to apps/mobile/.env) ──────────────────────────
# Replace with your machine's local IP (run: ipconfig or ifconfig)
EXPO_PUBLIC_API_URL=http://192.168.x.x:8080/api/v1
